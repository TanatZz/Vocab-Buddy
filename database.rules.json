{
  "rules": {
    "decks": {
      ".read": "auth != null && query.orderByChild == 'userId' && query.equalTo == auth.uid",
      ".indexOn": ["userId"],
      "$deckId": {
        ".read": "data.child('userId').val() === auth.uid",
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)"
      }
    },
    "words": {
      "$deckId": {
        ".read": "auth != null && root.child('decks').child($deckId).child('userId').val() === auth.uid",
        ".write": "auth != null && root.child('decks').child($deckId).child('userId').val() === auth.uid",
        ".indexOn": ["difficulty"]
      }
    },
    "studySessions": {
      "$userId": {
        ".read": "auth != null && $userId === auth.uid",
        ".write": "auth != null && $userId === auth.uid"
      }
    }
  }
}
